APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Tokyo
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
# アイドルタイムアウト（分）。スマホでタブを切ったあとも戻れるようにするには「ログイン状態を保持する」も利用してください。
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# 本番 HTTPS では true 推奨（セッション・Remember Cookie が送られない原因になることがあります）
SESSION_SECURE_COOKIE=

# Web「ログイン状態を保持する」用（暗号化 Cookie + m_user.access_token_web）
REMEMBER_WEB_COOKIE=nakatsuka_remember_web
REMEMBER_WEB_LIFETIME=43200

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# --- DB バックアップ（php artisan backup:database）---
# 日次実行する場合: cron で `* * * * * cd /path/to/app && /opt/php-8.3/bin/php artisan schedule:run`
# 上記に加え、本番 .env で true にすると毎日 03:15 に backup:database が走ります。
# BACKUP_DATABASE_SCHEDULE_ENABLED=false
# 既定は config で 365 日。短くする場合のみ指定（例: BACKUP_KEEP_DAYS=90）
# BACKUP_KEEP_DAYS=365
# 任意: 別サーバ等へ rsync（末尾スラッシュ不要のディレクトリ推奨）例: user@backup:/var/backups/nakatsuka
# BACKUP_RSYNC_DEST=
# BACKUP_MYSQLDUMP_PATH=/usr/bin/mysqldump
# BACKUP_SQLITE_PATH=/usr/bin/sqlite3

# 有給承認者の社員ID（カンマ区切り。未指定時は config/paid_leave.php の既定）
# PAID_LEAVE_APPROVER_STAFF_IDS=6,7,13,9,25,40

# DB認証失敗時の開発用フォールバックログイン（安全のため既定は false）
# ALLOW_DEV_LOGIN_FALLBACK=false
